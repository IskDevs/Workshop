"VertexlitGeneric"
{
	"$basetexture" "dannio/gordonramsay/head"
	"$bumpmap" "dannio/gordonramsay/bumpmap"
	"$normalmapalphaenvmapmask" 1
	"$blendtintbybasealpha" "1"
	"$nocull" "1"
	"$nodecal" "1"
   	$surfaceprop "metal"

    	$envmap "env_cubemap"
    	$envmaptint "[ .4 .4 .4]"
    	$envmapcontrast "1"
    	$envmapsaturation "1"
    	$envmapfresnel "1"

    	$phong "1"
    	$phongexponent "100"
    	$phongboost "2"
    	$phongfresnelranges "[ .3 .5 1]"

    	"$colorfix" "[1 1 1]"
    	"Proxies"
    	{
       		 "Equals"
       		 {
           			 srcVar1 $colorfix
          			 resultVar    $color
       		 }
    	}
}


