VertexLitGeneric
{
	$basetexture "models/smurfCat/smurfCat/grape_diff"
	$surfaceprop Metal

	$envmap "env_cubemap"
	$normalmapalphaenvmapmask 1
	$envmaptint "[0.70 0.70 0.70]"
	$envmapfresnel 0.34
	$envmaplightscale 1
	$envmaplightscaleminmax "[0 1]"
	$envmapanisotropy 1
	$envmapanisotropyscale 0.05

	$phong 1
	$phongexponenttexture "models/smurfCat/smurfCat/grape_phong"
	$phongfresnelranges "[0.06 0.41 3]"
	$phongboost 8

	//$ambientoccltexture "[your ambient occlusion here]"
	$ambientocclusion 1
}