patch {
	include "materials/models/debiddo/miss_hina/vertexlit_anime.vmt"
	insert {
		$basetexture "models/debiddo/miss_hina/body2"
		$lightwarptexture "models/debiddo/miss_hina/lightwarp_honkai3rd"
		$color2 " [ .9 .9 .9 ] "
		$rimlightboost ".5"
		$rimlightexponent "15"

		// Purpose: sample of dynamic tint HDR Overbright based where the player/entity is looking
		$lighting ".499"

		$MinLighting ".8"
		$MaxLighting ".95"
		$LightBoost ".85"
		$clr ".0"
		$dummy ".0"

		Proxies {
			// drive $lighting
			Pupil {
				TextureVar $basetexture
				TextureFrameNumVar $dummy
				PupilCloseRate .08
				PupilOpenRate .08
			}
			Subtract {
				srcVar1 $LightBoost
				srcVar2 $lighting
				resultVar $clr
			}
			// Clamp for limit and prevent to bright/dark
			Clamp {
				min $MinLighting
				max $MaxLighting
				srcVar1 $clr
				resultVar $clr
			}
			// Transfer the calc light from Pupil to $color
			Equals {
				srcVar1 $clr
				resultVar "$color2"
			}
      }
	}
}