VertexLitGeneric
{
	$basetexture "models/genshin_impact/eula/effect"
	$surfaceprop Flesh
                 $color2 "[1.8 1.8 4]"

	$lightwarptexture "models/genshin_impact/eula/toon_n"

	$translucent 1
	$nocull 1
	$phong 1
	$phongfresnelranges "[1 1 0.94]"
	$phongalbedotint 1
	$phongexponent 1
	$phongboost 0.8
	$phongalbedoboost 4

	$rimlight 1
	$rimlightexponent 5
	$rimlightboost 0.5
	$rimlightmask 1

	$rimmask 1
	$sineang 270
	$sineoff 0

	Proxies
	{
		TextureScroll
		{
			textureScrollVar "$basetexturetransform"
			textureScrollRate 1.3
			textureScale "$sineoff"
			textureScrollAngle "$sineang"
		}

		LinearRamp
		{
			rate 0.0001
			initialValue 1
			resultVar "$sineoff"
		}

		Sine
		{
			sinemin 269.9995
			sinemax 270.0015
			sineperiod 1
			timeoffset 2
			resultVar "$sineang"
		}
	}
}