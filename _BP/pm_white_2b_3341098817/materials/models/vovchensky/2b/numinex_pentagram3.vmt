"UnlitGeneric"
{
	"$basetexture""models/vovchensky/2b/numinex_pentagram3"
	 $color "{ 1 0 0 }"
	"$additive" 1
	"$translucent" 1
	"$selfillum" 1
	"$selfillumtint" "{ 1 0 0 }"

  "$angle" 0.0
        "$translate" "[0.0 0.0]"
        "$center" "[0 0]"

        "Proxies"
        {
            "LinearRamp"
            {
                "rate" -65
                "initialValue" 0.0
                "resultVar" "$angle"
            }

            "TextureTransform"
            {

                "rotateVar" "$angle"

                "resultVar" "$basetexturetransform"
            }
        }
    }





