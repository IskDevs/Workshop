"VertexLitGeneric"
{
    "$basetexture" "Arty\Codmw2023\MP\SpecGru\Jet\Latern\Head\Head_rgb"
    "$bumpmap" "Arty\Codmw2023\MP\SpecGru\Jet\Latern\Head\Head_n"
    "$phongexponenttexture" "Arty\Codmw2023\MP\SpecGru\Jet\Latern\Head\Head_e"

    /////////////////
    $EmissiveBlendEnabled         1                    // Enable EmissiveBlend. Like $selfillum 1    
    $EmissiveBlendStrength         1                     // how strong the entire glow effect is.
    $EmissiveBlendTexture         color\white            // This will be useless, but is required.
    $EmissiveBlendBaseTexture     "Arty\Codmw2023\MP\SpecGru\Jet\Latern\Head\Head_m"    // this is the glowing texture.vtf
    $EmissiveBlendFlowTexture     color\white             // EmmisiveBlend can "flow" or move. But ours is static, so a white texture is used.
    $EmissiveBlendTint             " [ 1 1 1 ] "        // RGB glow intensity. Leave at 1 1 1. This can be used to change how strong each color should glow. So instead of using a darker red color, you may use [.5 1 1] to have red glow half as strong.
    /////////////////

    "$phong" "1"
    "$phongboost" "1"
    "$phongalbedotint" "1"
    "$phongalbedoboost" "10"                                //toy around with this
    "$phongfresnelranges" "[1 0.1 0]"

    //rimlight doesn't properly show in hlmv, make sure you're changing these values in game
    "$rimlight" "1"
    "$rimlightexponent" "100"
    "$rimmask" "1"
    "$rimlightboost" "1"
       
    /////////////////
    "$normalmapalphaenvmapmask" "1"                         //do not touch this
    /////////////////

    "$envmap" "Arty\Codmw2023\MP\SpecGru\Jet\Latern\envmaps\specularity_00"
    "$envmaptint" "[0.11 0.102 0.094]"                 

    //remove this if not using MWB
    "Proxies"
    {
        "MwEnvMapTint"
        {
            "min" "0"
            "max" "1"
            "envmap" "Arty\Codmw2023\MP\SpecGru\Jet\Latern\envmaps\specularity_00"
            "color" "[0.11 0.102 0.094]"
        }
    }
}