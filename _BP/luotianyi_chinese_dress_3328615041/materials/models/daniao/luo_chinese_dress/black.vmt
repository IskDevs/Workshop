patch
{
	include "materials/models/survivors/survivors_it_shared.vmt"
	insert
{
	"$basetexture" "models/daniao/luo_chinese_dress/black"
	"$nodecal" 1
	"$phong" "1"
	"$phongboost"	"2"
	"$phongexponent" "8"
	"$phongfresnelranges" "[.25 1 .5]"
	"$envmap" "env_cubemap"
	$envmapfresnel "1"								//increase highlights at grazing angles, just like phong
	$envmaptint "[0.01 0.01 0.01]"
	"$bumpmap" "models/daniao/luo_chinese_dress/normal"
	"$lightwarptexture" "models/daniao/luo_chinese_dress/toon_all"
	"$rimlight"               "1"
	"$rimlightexponent"       "5"
	"$rimlightboost"          "3"
}
}
