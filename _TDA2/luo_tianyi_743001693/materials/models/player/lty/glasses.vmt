"VertexlitGeneric"
{
	"$basetexture" "models/player/lty/glasses"

	"$basemapalphaenvmapmask" 	"1"
	"$envmap"			"env_cubemap"
	"$envmapfresnel" 			"1"
	"$envmapFresnelMinMaxExp"		"[1 .4 4]"
	"$envmaptint"        "[1 1 1]"
	
	// "$basemapalphaphongmask" 	"1"
	// "$phong" "1"
	// "$phongboost"	"1"
	// "$phongalbedotint" "1"
	// "$phongexponenttexture" "models/player/lty/shader/phong_exp"
	// "$phongfresnelranges"	"[1 .5 .5]"

	// "$lightwarptexture" "models/player/lty/shader/cartoon_shader"

	"$halflambert" "1"	
	"$AmbientOcclusion" "0"	
	"$nocull" "1"
	"$nodecal" "1"
//	"$alphatest" "1"
//	"$additive" "1"
	"$translucent" "1"
	"$surfaceprop" "glass"
	
	// Rim lighting parameters
	"$rimlight" "1"												// To enable rim lighting (requires phong)
	"$rimlightexponent" "3"										// Exponent for phong component of rim lighting	
	"$rimlightboost" "4"										// Boost for ambient cube component of rim lighting
}