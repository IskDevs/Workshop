"VertexlitGeneric"
{
	"$basetexture" "models/monika/alpha"
	"$bumpmap"    "models/monika/skin_shiny"
	"$nodecal" "1"
	"$translucent" 1
	"$phong" 1
	"$nocull" 1

	"$phongboost" "1"
	"$phongexponent" 7

	"$envmap" "env_cubemap"
	"$envmaptint" "[.9 .9 .9]"
	"$envmapfresnel" "1"

	"$phongfresnelranges" "[0.1 0.1 0.1]"

	"$colorfix" "{255 255 255}"
	"Proxies"
	{
		"Equals"
		{
			srcVar1 $colorfix
			resultVar	$color
		}
	}
}
