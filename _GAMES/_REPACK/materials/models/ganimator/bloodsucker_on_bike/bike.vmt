"VertexlitGeneric"
{
	"$basetexture" "models/ganimator/bloodsucker_on_bike/paint"
	"$basemapalphaphongmask" 1
	"$nodecal" "1"
	"$phong" "1"
	"$phongexponent" "15"
	"$phongboost"	"1"
	"$envmap" "env_cubemap"
	"$envmapfresnel" "1.5"
	"$phongfresnelranges" "[.4 .7 2]"
	"$envmaptint" "[0.25 0.25 0.25]"
	"$phongfix" "{20 20 20}"

	Proxies
	{
		Equals
		{
			srcVar1	$color
			resultVar	$phongtint
		}
		Add
		{
			srcVar1 $phongfix
			srcVar2 $phongtint
			resultVar $phongtint
		}
	}
}
