"VertexlitGeneric"
{
	"$basetexture" "models/kapuyas/multiversus/adventure_time/finn/doomguy/Coins/Red"
	"$bumpmap" "models/kapuyas/multiversus/adventure_time/finn/doomguy/shared/blanknormal"
