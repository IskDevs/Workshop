"VertexLitGeneric"
{
	"$basetexture" "models\sasamin\oneshot\shadoweyes"
	"$nodecal" "1"

	"$detail" "models\sasamin\oneshot\shadoweyes"
       	"$detailscale" "1"        //scales the detail texture to same size as diffuse.
      	"$detailblendfactor" ".5"  //lower values make the texture less visible. 0.0 - 1.0
      	"$detailblendmode" "5"    //6 also works.
}