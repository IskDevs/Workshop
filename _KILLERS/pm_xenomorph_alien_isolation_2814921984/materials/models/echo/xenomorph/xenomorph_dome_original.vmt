"VertexlitGeneric"
{
//note from Echo
//full credits to Zachariah for the textures I didn't make them or port them.
	"$basetexture" "models/echo/xenomorph/Xenomorph_D"
	"$bumpmap" "models/echo/xenomorph/isonormal"
       	"$halflambert" "1"
	$surfaceprop alienflesh
	$phong 1

	$phongboost 0.5
	$phongfresnelranges "[1 1 1]"
	"$phongexponent" 30

	//"$phongexponenttexture" "models/echo/xenomorph/isokspec"
	//"$phongwarptexture" "models/echo/xenomorph/oil_phongwarp"

	$detail "models/echo/xenomorph/xenomorph_s"
	$detailblendmode "0"
	$detailscale "1"
	$detailblendfactor "1"

	$envmap "env_cubemap"
	$envmaptint "[0.02 0.02 0.02]"
}






