"VertexlitGeneric"
{
//note from Echo
//full credits to Zachariah for the textures I didn't make them or port them.

	"$basetexture" "models/echo/xenomorph/isoxenok"
	"$bumpmap" "models/echo/xenomorph/isonormal"
       	"$halflambert" "1"
	$surfaceprop alienflesh
	$phong 1
	$phongtint "[0.39 0.93 0.38]"
	$phongboost .5
	$phongfresnelranges "[0.3 .5 1]"
	"$phongexponent" 30


	//"$phongexponenttexture" "models/echo/xenomorph/isokspec"
	"$phongwarptexture" "models/echo/xenomorph/bluephongwarp"

	$detail "models/echo/xenomorph/detail_metal11"
	$detailblendmode "0"
	$detailscale "15"
	$detailblendfactor "0.8"
}









