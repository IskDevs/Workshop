"UnlitGeneric"
{
    "$basetexture" "models\glamrock\secretofthemimic\Animatronics\Mimic\Colorable_Y"

    Proxies
    {
        PlayerColor
        {
            resultVar   $color2
            default     0.53 0.46 0.39
        }
        Clamp
        {
            min 0.01
            max 1.50
            srcVar1 "$color2"
            resultVar "$color2"
        }
        Clamp
        {
            min 0.3
            max 0.7
            srcVar1 "$color2"
            resultVar "$phongtint"
        }
    }   
}