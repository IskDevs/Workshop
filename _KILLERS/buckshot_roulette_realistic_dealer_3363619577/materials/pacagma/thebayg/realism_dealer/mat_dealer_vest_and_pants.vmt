"VertexLitGeneric"
{
    "$basetexture" "pacagma\thebayg\realism_dealer\MAT_Dealer_Vest_and_Pants_rgb"
    "$bumpmap" "pacagma\thebayg\realism_dealer\MAT_Dealer_Vest_and_Pants_n"
    "$phongexponenttexture" "pacagma\thebayg\realism_dealer\MAT_Dealer_Vest_and_Pants_e"

    /////////////////
    "$color2" "[0 0 0]"                                     //do not touch this
    "$blendtintbybasealpha" "1"                             //do not touch this
    /////////////////

    "$phong" "1"
    "$phongboost" "0.1"
    "$phongalbedotint" "1"
    "$phongalbedoboost" "10"                                //toy around with this
    "$phongfresnelranges" "[1 0.1 0]"

    //rimlight doesn't properly show in hlmv, make sure you're changing these values in game
    "$rimlight" "1"
    "$rimlightexponent" "100"
    "$rimmask" "1"
    "$rimlightboost" "1"
       
    /////////////////
    "$normalmapalphaenvmapmask" "1"                         //do not touch this
    /////////////////

    //"$envmap" "\specularity_75"
    "$envmaptint" "[0.075 0.071 0.071]"                 

    //remove this if not using MWB
    "Proxies"
    {
        "MwEnvMapTint"
        {
            "min" "0"
            "max" "1"
            "envmap" "\specularity_75"
            "color" "[0.075 0.071 0.071]"
        }
    }
}