"VertexLitGeneric"
{
	"$baseTexture"			"zerochain/props_pumpkinnight/sign/zpn_sign_diff"

	"$bumpMap"				"zerochain/props_pumpkinnight/sign/zpn_sign_nrm"

	"$surfaceprop" "metal"
	"$model" 1
	"$halflambert" 1
	
	$phong 1
	$phongexponenttexture "zerochain/props_pumpkinnight/sign/zpn_sign_exp"	
	$phongfresnelranges "[1 2 3]"
	$phongalbedotint 1
	$phongboost 0.25
	$phongalbedoboost 100
	
	$envmap env_cubemap
	"$normalmapalphaenvmapmask" "1"	
	$envmaptint "[1 1 1]"
	$envmapfresnel 1
	$envmapFresnelMinMaxExp "[1 2 3]"
	
	$rimlight               1
	$rimlightexponent      15
	$rimlightboost         0.1
	$rimmask 1	
	

	$detail detail\noise_detail_01 // e.g. for brickwork, concrete...
	$detailscale 5
	$detailblendfactor 0.2
	$detailblendmode 0	
}
