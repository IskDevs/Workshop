"VertexLitGeneric"
{
	"$baseTexture"			"zerochain/props_christmas/ghost/zpn_ghost_santa_diff"
	//"$bumpMap"				"zerochain/props_christmas/ghost/zpn_ghost_santa_nrm"
	

	"$halflambert" "1"
	"$nodecal" "1"

	//$additive 1
	//$nocull 0
	
	// Emissive Scroll Pass
	"$emissiveBlendEnabled"     "1"
	"$emissiveBlendTexture" "zerochain/props_christmas/ghost/zpn_ghost_santa_blend"
	"$emissiveBlendBaseTexture" "zerochain/props_christmas/ghost/zpn_ghost_santa_em"
	"$emissiveBlendFlowTexture" "zerochain/props_pumpkinnight/ghost/zpn_ghost_flow"
	"$emissiveBlendTint"        "[0.5 0.5 0.5]"
	"$emissiveBlendStrength" "1"
	"$emissiveBlendScrollVector" "[0.1 0.12]"

	"$time" "0"
	"Proxies"
	{
		"CurrentTime"
		{
			"resultVar" "$time"
		}
	}

	$selfillum 1
	$selfillumtint "[0.5 0.5 1]"
	
	$additive 0
	$nocull 0
		
}
