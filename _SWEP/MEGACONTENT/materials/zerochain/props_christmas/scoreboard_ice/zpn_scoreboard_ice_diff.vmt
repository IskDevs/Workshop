"VertexLitGeneric"
{
	"$color"				"[1 1 1]"
	"$baseTexture"			"zerochain/props_christmas/scoreboard_ice/zpn_scoreboard_ice_diff"
	"$bumpMap"				"zerochain/props_christmas/scoreboard_ice/zpn_scoreboard_ice_nrm"
	
	"$surfaceprop" "metal"
	"$model" 1
	"$halflambert" 1

	$phong 1
	$phongexponenttexture "zerochain/props_christmas/scoreboard_ice/zpn_scoreboard_ice_exp"	
	$phongfresnelranges "[1 4 6]"
	$phongalbedotint 1
	$phongboost 1
	$phongalbedoboost 100
	
	
	$envmap env_cubemap
	"$normalmapalphaenvmapmask" "1"	
	$envmaptint "[1 1 1]"
	$envmapfresnel 1
	$envmapFresnelMinMaxExp "[1 2 3]"
	
	$rimlight               1
	$rimlightexponent      15
	$rimlightboost         0.1
	$rimmask 1	
	

	$detail detail\noise_detail_01 // e.g. for brickwork, concrete...
	$detailscale 5
	$detailblendfactor 0.1
	$detailblendmode 0		
}
