"VertexLitGeneric"
{
	"$color"				"[1 1 1]"
	"$baseTexture"			"zerochain/props_christmas/snowboss/zpn_snowboss_ice_diff"
	"$bumpMap"				"zerochain/props_christmas/snowboss/zpn_snowboss_ice_nrm"

	"$surfaceprop" "snow"
	"$model" 1
	$halflambert 1
	
	$additive 0
	//$nocull 0
	$alphatest 1
	
	$phong 1
	$phongexponent 1
	$phongfresnelranges "[1 1 1]"
	$phongboost 1
	
	$envmap env_cubemap
	"$normalmapalphaenvmapmask" "1"	
	$envmaptint "[1 1 1]"
	$envmapfresnel 1
	$envmapFresnelMinMaxExp "[1 2 3]"
	
	$rimlight               1
	$rimlightexponent      15
	$rimlightboost         0.1
	$rimmask 1	


	// Emissive Scroll Pass
	"$emissiveBlendEnabled"     "1"
	"$emissiveBlendTexture" "zerochain/props_christmas/snowboss/null"
	"$emissiveBlendBaseTexture" "zerochain/props_christmas/snowboss/zpn_snowboss_ice_em"
	"$emissiveBlendFlowTexture" "zerochain/props_christmas/snowboss/null"
	"$emissiveBlendTint"        "[1 1 1]"
	"$emissiveBlendStrength" "1"
	"$emissiveBlendScrollVector" "[0.1 0.1]"	
	
	"$TimeOffset" 0
	
		
	
	"$time" "0"
	"Proxies"
	{
		EntityRandom
		{
			resultVar $TimeOffset // write to custom var
		}
		
		"CurrentTime"
		{
			"resultVar" "$time"
		}
		
		"Sine"
		{
            "sineperiod" 5
            "sinemin" 0.5
			"sinemax" 2
			"timeoffset" "$TimeOffset"
            "resultVar" "$emissiveBlendTint[0]"
		}
		
		"Sine"
		{
            "sineperiod" 5
            "sinemin" 0.5
			"sinemax" 2
			"timeoffset" "$TimeOffset"
            "resultVar" "$emissiveBlendTint[1]"
		}
		
		"Sine"
		{
            "sineperiod" 5
            "sinemin" 0.5
			"sinemax" 2
			"timeoffset" "$TimeOffset"
            "resultVar" "$emissiveBlendTint[2]"
		}	
	}
	
}