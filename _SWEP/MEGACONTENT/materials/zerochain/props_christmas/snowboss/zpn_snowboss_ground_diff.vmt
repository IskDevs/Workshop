"VertexLitGeneric"
{
	"$color"				"[1 1 1]"
	"$baseTexture"			"zerochain/props_christmas/snowboss/zpn_snowboss_ground_diff"
	"$bumpMap"				"zerochain/props_christmas/snowboss/zpn_snowboss_ground_nrm"

	"$surfaceprop" "snow"
	"$model" 1
	$halflambert 1
	
	$phong 1
	$phongexponent 1
	$phongfresnelranges "[1 4 6]"
	$phongboost 1
	
	$envmap env_cubemap
	"$normalmapalphaenvmapmask" "1"	
	$envmaptint "[1 1 1]"
	$envmapfresnel 1
	$envmapFresnelMinMaxExp "[1 2 3]"
	
	$rimlight               1
	$rimlightexponent      15
	$rimlightboost         0.1
	$rimmask 1	

	$detail detail\noise_detail_01 // e.g. for brickwork, concrete...
	$detailscale 20
	$detailblendfactor 0.3
	$detailblendmode 0
	
}