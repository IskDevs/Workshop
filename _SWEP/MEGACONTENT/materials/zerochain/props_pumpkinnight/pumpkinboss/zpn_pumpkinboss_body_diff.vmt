"VertexLitGeneric"
{
	"$color"				"[1 1 1]"
	"$baseTexture"			"zerochain/props_pumpkinnight/pumpkinboss/zpn_pumpkinboss_body_diff"
	
	"$bumpMap"				"zerochain/props_pumpkinnight/pumpkinboss/zpn_pumpkinboss_body_nrm"

	"$surfaceprop" "metal"
	"$model" 1
	$halflambert 1
	
	$phong 1
	$phongexponenttexture "zerochain/props_pumpkinnight/pumpkinboss/zpn_pumpkinboss_body_exp"	
	$phongfresnelranges "[1 1 1]"
	$phongalbedotint 1
	$phongboost 1
	$phongalbedoboost 1
	
	$envmap env_cubemap
	"$normalmapalphaenvmapmask" "1"	
