"VertexLitGeneric"
{
	"$baseTexture"			"zerochain/props_pumpkinnight/pumpkinboss/zpn_pumpkinboss_main_diff"
	
	"$bumpMap"				"zerochain/props_pumpkinnight/pumpkinboss/zpn_pumpkinboss_body_nrm"

	"$surfaceprop" "metal"
	"$model" 1
	"$halflambert" 1
	
	$phong 1
	$phongexponenttexture "zerochain/props_pumpkinnight/pumpkinboss/zpn_pumpkinboss_body_exp"	
	$phongfresnelranges "[1 1 1]"
	$phongalbedotint 1
	$phongboost 1
	$phongalbedoboost 1
	
	$envmap env_cubemap
	"$normalmapalphaenvmapmask" "1"	
	$envmaptint "[0.70 0.70 0.70]"
	$envmapfresnel 1
	$envmapFresnelMinMaxExp "[1 2 3]"
	
	$rimlight               1
	$rimlightexponent      15
	$rimlightboost         0.1
	$rimmask 1	
	
	$emissiveBlendEnabled "1"
	$emissiveBlendTexture "zerochain/props_pumpkinnight/pumpkinboss/null" 
	$emissiveBlendBaseTexture "zerochain/props_pumpkinnight/pumpkinboss/zpn_pumpkinboss_main_em"
	$emissiveBlendFlowTexture "zerochain/props_pumpkinnight/pumpkinboss/null"
	//$emissiveBlendTint "[1 0.6 0]"
	$emissiveBlendStrength "1"
	$emissiveBlendScrollVector "[0.1]"

	$selfillum 1
	$selfillumtint "[0.5 0.5 0.5]"	
	
	$detail detail\noise_detail_01 // e.g. for brickwork, concrete...
	$detailscale 20
	$detailblendfactor 0.5
	$detailblendmode 0
}
