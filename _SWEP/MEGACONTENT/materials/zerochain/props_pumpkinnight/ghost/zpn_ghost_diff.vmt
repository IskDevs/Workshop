"VertexLitGeneric"
{
	"$baseTexture"			"zerochain/props_pumpkinnight/ghost/zpn_ghost_diff"
	

	"$halflambert" "1"
	"$nodecal" "1"

	// Rim lighting parameters
	"$rimlight" "1"												// To enable rim lighting (requires phong)
	"$rimlightexponent" "1"										// Exponent for phong component of rim lighting	
	"$rimlightboost" "0.5"										// Boost for ambient cube component of rim lighting


	// Emissive Scroll Pass
	"$emissiveBlendEnabled"     "1"
	"$emissiveBlendTexture" "zerochain/props_pumpkinnight/ghost/zpn_ghost_blend"
	"$emissiveBlendBaseTexture" "zerochain/props_pumpkinnight/ghost/zpn_ghost_em"
	"$emissiveBlendFlowTexture" "zerochain/props_pumpkinnight/ghost/zpn_ghost_flow"
	"$emissiveBlendTint"        "[0.5 0.5 0.5]"
	"$emissiveBlendStrength" "1"
	"$emissiveBlendScrollVector" "[0.1 0.12]"

	"$time" "0"
	"Proxies"
	{
		"CurrentTime"
		{
			"resultVar" "$time"
		}
	}

	$selfillum 1
	$selfillumtint "[0.5 0.5 0.5]"
	
	$additive 0
	$nocull 0
		
}
