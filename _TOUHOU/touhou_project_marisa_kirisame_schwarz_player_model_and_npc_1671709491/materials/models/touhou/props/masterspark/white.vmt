"VertexlitGeneric"
{
	"$basetexture" "models\touhou\props\masterspark\intex"
		"$lightwarptexture" "models/touhou/shader/face_shader"


$translucent "1"
$ambientocclusion "0"


	$selfillummask "models\touhou\props\masterspark\intex"

//$selfillum "1"
$selfillumtint "[1 1 1]"


	//$emissiveBlendEnabled 1 								//enable this weird version of selfillum
	$emissiveBlendTexture     "dev/null" 							//ignore this for now, it's hacky
	"$emissiveBlendBaseTexture" "models\touhou\props\masterspark\intex"

	$emissiveBlendFlowTexture  "dev/null" 	
	$emissiveBlendTint "[1 1 1]" 								//full glow brightness
	$emissiveBlendStrength .1								//half glow intensity ( don't worry, still plenty, don't want to go up to 1 )
	$emissiveBlendScrollVector "[0 0]"							//ignore this, it's only used in certain cases							//full glow brightness


"$color2" "[ 1 1 1]"

//$phong          "1"
	$phongboost     "0.8"
	$phongexponent      "20"
	"$phongexponenttexture" "models/touhou/shader/phong_exp"
	"$phongfresnelranges"	"[.1 .1 .1]"

	"$rimlight"               "1"
	"$rimlightexponent"       "18"
	"$rimlightboost"          "1.7"


	//	"$sin_alpha" 0
//	"$sin_scale" 0
//	"$sin_ofs" 0
//	"$sin_rotate" 0

//	"$scale" 0.9
//	"$scale2" 1.0
//	"$scale_ofs" 0
//	"$texoffset"	"[0 0]"
//	"$midofs" 0.0


	"Proxies"
	{


"TextureScroll" 
{ 
               "textureScrollVar" "$basetexturetransform"
                "textureScrollRate" 2
                "textureScrollAngle" 0
}

"Sine" //"$sin_alpha"
		{
			"resultVar"	"$alpha"
			"sineperiod"	3
			"sinemin"	.6
			"sinemax"	1
		}

}
